# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_pay

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# ── Stellar Network ────────────────────────────────────────────────────────────
STELLAR_RPC_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK=TESTNET

# ── Treasury ───────────────────────────────────────────────────────────────────
TREASURY_PRIVATE_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TREASURY_WALLET_ADDRESS=GTREASURYADDRESSXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPPORTED_ASSETS=USDC,ARS

# ── Blockchain Nodes ───────────────────────────────────────────────────────────
BTC_NODE_URL=https://bitcoin-node.example.com
ETH_NODE_URL=https://ethereum-node.example.com
