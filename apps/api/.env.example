# Server
PORT=3000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/stellar_pay

# Stellar Network
STELLAR_NETWORK=TESTNET
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Treasury (Stellar secret key - starts with 'S', 56 characters)
TREASURY_PRIVATE_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TREASURY_WALLET_ADDRESS=GDTREASURYADDRESSXXXXXX
SUPPORTED_ASSETS=USDC,ARS

# Blockchain Node URLs
BTC_NODE_URL=https://btc-node.example.com
ETH_NODE_URL=https://eth-node.example.com

# Redis (for queue management)
REDIS_URL=redis://localhost:6379
