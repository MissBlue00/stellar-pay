generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentIntentStatus {
  PENDING
  DETECTED
  CONFIRMED
  FAILED
}

model Merchant {
  id             String            @id @default(cuid())
  name           String
  legalName      String?
  email          String?           @unique
  status         MerchantStatus    @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  users          MerchantUser[]
  customers      Customer[]
  paymentIntents PaymentIntent[]
  subscriptions  Subscription[]
  treasuryWallets TreasuryWallet[]
  payouts        Payout[]
  webhookEvents  WebhookEvent[]
  apiKeys        ApiKey[]
}

model ApiKey {
  id         String   @id @default(cuid())
  merchantId String
  keyHash    String   @unique @map("key_hash")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
}

  paymentIntents   PaymentIntent[]
  webhookEndpoints WebhookEndpoint[]

  @@map("merchants")
}

model PaymentIntent {
  id         String                @id @default(uuid()) @db.Uuid
  merchantId String                @map("merchant_id") @db.Uuid
  amount     Decimal               @db.Decimal(18, 2)
  currency   String                @db.VarChar(3)
  status     PaymentIntentStatus   @default(PENDING)
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("payment_intents")
}

model TreasuryAsset {
  symbol       String @id @db.VarChar(10)
  totalMinted  Decimal @default(0) @map("total_minted") @db.Decimal(36, 2)
  totalReserved Decimal @default(0) @map("total_reserved") @db.Decimal(36, 2)

  @@map("treasury_assets")
}

model WebhookEndpoint {
  id         String   @id @default(uuid()) @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  url        String
  secret     String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("webhook_endpoints")
}
